# genai-lab — 환경 변수 예시
# 이 파일을 .env로 복사한 뒤 실제 키를 채워 넣으세요.
# .env 파일이 있으면 dev 서버가 시작될 때 서버 사이드에서 1회 클라이언트로 주입합니다.
# 비어 있어도 됩니다 — Settings 페이지에서 직접 입력해도 동일하게 동작합니다.

# GitHub Models (무료 티어, 권장 시작 옵션)
# https://github.com/settings/personal-access-tokens 에서 fine-grained PAT 생성 후
# Account permissions → Models 권한을 read로 설정.
GITHUB_TOKEN=

# OpenAI (선택)
OPENAI_API_KEY=

# Azure OpenAI (선택)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Hugging Face (선택, 16번 레슨용)
HUGGING_FACE_API_KEY=

# 원본 generative-ai-for-beginners 레포 경로
# scripts/sync-content.ts 가 이 경로에서 마크다운/코드를 읽어 content/ 로 스냅샷합니다.
# 기본값은 ../generative-ai-for-beginners 입니다.
SOURCE_REPO_PATH=../generative-ai-for-beginners
